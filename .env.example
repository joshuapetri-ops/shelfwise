# Server-only — used by Vercel serverless function /api/claude. Do NOT prefix with VITE_.
ANTHROPIC_API_KEY=your_api_key_here

# Upstash Redis (used for rate limiting on /api/claude). Vercel's Upstash marketplace
# integration sets these automatically; otherwise copy from your Upstash console.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
