{
  "lexicon": 1,
  "id": "app.shelfwise.criteriaTemplate",
  "defs": {
    "main": {
      "type": "record",
      "description": "A rating criteria template that can be shared.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["name", "criteria", "createdAt"],
        "properties": {
          "name": { "type": "string", "maxLength": 128 },
          "criteria": {
            "type": "array",
            "items": { "type": "ref", "ref": "#criterionDef" },
            "maxLength": 20
          },
          "createdAt": { "type": "string", "format": "datetime" }
        }
      }
    },
    "criterionDef": {
      "type": "object",
      "required": ["id", "name", "max", "type"],
      "properties": {
        "id": { "type": "string", "maxLength": 64 },
        "name": { "type": "string", "maxLength": 128 },
        "emoji": { "type": "string", "maxLength": 8 },
        "max": { "type": "integer", "minimum": 1, "maximum": 100 },
        "type": { "type": "string", "knownValues": ["stars", "slider"] }
      }
    }
  }
}
